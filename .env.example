# Copy this file to ".env" and fill in your keys.
# The real .env is git-ignored and must NEVER be committed.
#
# You only NEED GEMINI_API_KEY. The others are optional fallbacks: when one
# provider's free quota runs out, the server automatically switches to the next
# one in this order, keeping the conversation context. Add as many as you like.

# 1) Google Gemini  (required)  -> https://aistudio.google.com/apikey
GEMINI_API_KEY=your_new_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# 2) Groq  (free, no card)  -> https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# 3) OpenRouter  (free models, no card)  -> https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 4) Mistral  (free tier)  -> https://console.mistral.ai/
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest

# Simple per-IP rate limit (requests per minute)
RATE_LIMIT_PER_MIN=20
