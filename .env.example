# Copy this file to ".env" and fill in your real key.
# The real .env is git-ignored and must NEVER be committed.

# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_new_gemini_api_key_here

# Optional: which Gemini model to use (gemini-1.5-flash is retired; use a current one)
GEMINI_MODEL=gemini-2.5-flash

# Optional: simple per-IP rate limit (requests per minute)
RATE_LIMIT_PER_MIN=20
