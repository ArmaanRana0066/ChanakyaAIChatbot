# Copy this file to ".env" and fill in your real keys.
# The real .env is git-ignored and must NEVER be committed.

# --- Primary provider (required) ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Simple per-IP rate limit (requests per minute)
RATE_LIMIT_PER_MIN=20

# --- Fallback providers (OPTIONAL, all free + no credit card) ---
# The server auto-switches between providers, in order, when one's quota is exhausted.
# Only the ones you set are used. Conversation context is preserved across the switch.
#
# MULTIPLE KEYS PER PROVIDER: put several comma-separated keys in any of these vars to get
# automatic key rollover — if one key dies/expires, the next is used. Example:
#   GROQ_API_KEY=key_one,key_two,key_three
#   GEMINI_API_KEY=primary_key,backup_key

# Groq — https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Mistral — https://console.mistral.ai/
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest
